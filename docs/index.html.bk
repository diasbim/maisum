<!DOCTYPE html>
<html lang="pt-MZ">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MaisUm | App de fidelização para barbearias e salões em Maputo</title>
<meta name="description" content="MaisUm é uma app de fidelização para barbearias e salões em Maputo. Regista vendas, atribui pontos e traz clientes de volta pelo WhatsApp sem complicar o atendimento.">
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
<meta name="application-name" content="MaisUm">
<meta name="plausible-domain" content="">
<meta property="og:title" content="MaisUm | App de fidelização para barbearias e salões em Maputo">
<meta property="og:description" content="Regista a venda, atribui pontos e chama o cliente de volta no WhatsApp sem travar o atendimento.">
<meta property="og:type" content="website">
<meta property="og:locale" content="pt_MZ">
<meta property="og:site_name" content="MaisUm">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="MaisUm | Fidelização simples para barbearias em Maputo">
<meta name="twitter:description" content="Mais clientes a voltar com menos confusão no balcão, Android no centro e WhatsApp como canal de retorno.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "MaisUm",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Android",
      "description": "App de fidelização para barbearias e salões em Maputo. Ajuda a registar vendas, atribuir pontos e trazer clientes de volta pelo WhatsApp.",
      "areaServed": {
        "@type": "City",
        "name": "Maputo"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "MZN",
        "availability": "https://schema.org/PreOrder"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "O cliente também precisa de instalar a app?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Não. O cliente recebe tudo no WhatsApp, o que reduz a fricção e aumenta a chance de voltar."
          }
        },
        {
          "@type": "Question",
          "name": "Funciona quando a internet falha?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim. A venda pode ser guardada e sincronizada depois. A equipa não precisa parar por causa da internet."
          }
        },
        {
          "@type": "Question",
          "name": "É simples para equipas pequenas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim. O foco é uso rápido, pouco texto e pouca aprendizagem. Foi feito para equipas pequenas e ambientes corridos."
          }
        },
        {
          "@type": "Question",
          "name": "Como dou o próximo passo?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Falas connosco no WhatsApp, vês rapidamente se o fluxo encaixa no teu balcão e decides sem complicação."
          }
        }
      ]
    }
  ]
}
</script>
<style>
:root{
  --bg:#f5efe3;
  --ink:#111717;
  --ink-soft:#455154;
  --panel:#fffaf1;
  --panel-strong:#fffdf8;
  --panel-dark:#12212a;
  --line:rgba(17,23,23,.12);
  --line-strong:rgba(17,23,23,.22);
  --sand:#eadfc9;
  --brand:#f66b2d;
  --brand-deep:#c94b14;
  --leaf:#1f8f61;
  --sky:#87c7df;
  --gold:#ebb84f;
  --cream:#fff4dd;
  --shadow:0 24px 60px rgba(78,48,20,.12);
  --shadow-soft:0 14px 36px rgba(78,48,20,.08);
  --radius-xl:32px;
  --radius-lg:24px;
  --radius-md:18px;
  --max:1180px;
}
*,:before,:after{box-sizing:border-box}
html{scroll-behavior:smooth}
body,h1,h2,h3,p,ul{margin:0}
body{
  font-family:"Manrope",sans-serif;
  background:
    radial-gradient(circle at top left,rgba(246,107,45,.14),transparent 28%),
    radial-gradient(circle at top right,rgba(31,143,97,.12),transparent 24%),
    linear-gradient(180deg,#f8f3e8 0%,#f4eadc 42%,#f7f1e8 100%);
  color:var(--ink);
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%}
button,input,select,textarea{font:inherit}
.wrap{width:min(var(--max),calc(100% - 28px));margin:0 auto}
.skip-link{position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden}
.skip-link:focus{left:16px;top:16px;width:auto;height:auto;padding:10px 14px;border-radius:12px;background:#111;color:#fff;z-index:100}
.site-header{position:sticky;top:0;z-index:30;background:rgba(248,243,232,.88);border-bottom:1px solid rgba(17,23,23,.08);-webkit-backdrop-filter:blur(18px);backdrop-filter:blur(18px)}
.site-header .wrap{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:14px 0}
.brand{display:flex;align-items:center;gap:12px;min-width:0}
.brand img{width:42px;height:42px;object-fit:contain}
.brand-copy{display:flex;flex-direction:column;line-height:1}
.brand-copy strong,.brand-copy span{font-family:"Space Grotesk",sans-serif}
.brand-copy strong{font-size:1rem;letter-spacing:-.04em}
.brand-copy span{font-size:.76rem;color:var(--ink-soft)}
.nav{display:none;align-items:center;gap:20px}
.nav a{font-size:.95rem;color:var(--ink-soft);transition:color .18s ease}
.nav a:hover,.nav a:focus-visible,.footer-links a:hover,.footer-links a:focus-visible{color:var(--ink)}
.header-actions{display:flex;align-items:center;gap:10px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;min-height:50px;padding:0 18px;border-radius:999px;border:1px solid transparent;font-size:.96rem;font-weight:800;letter-spacing:-.02em;transition:transform .18s ease,box-shadow .18s ease,background-color .18s ease,border-color .18s ease,color .18s ease;cursor:pointer}
.btn:hover,.btn:focus-visible{transform:translateY(-1px)}
.btn:focus-visible,.nav a:focus-visible,.text-link:focus-visible,.faq-item summary:focus-visible{outline:3px solid rgba(246,107,45,.26);outline-offset:3px}
.btn-primary{background:linear-gradient(135deg,var(--brand) 0%,#ff8d49 100%);color:#fff;box-shadow:0 18px 42px rgba(246,107,45,.25)}
.btn-secondary{background:rgba(255,255,255,.62);border-color:var(--line);color:var(--ink)}
.btn-secondary:hover,.btn-secondary:focus-visible{background:#fff}
.btn-dark{background:var(--panel-dark);color:#fff;box-shadow:0 18px 42px rgba(18,33,42,.18)}
.btn-ghost{border-color:var(--line);color:var(--ink-soft);background:transparent}
.text-link{display:inline-flex;align-items:center;gap:10px;font-weight:800;color:var(--brand-deep)}
.section{padding:72px 0}
.eyebrow{display:inline-flex;align-items:center;gap:10px;padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.64);border:1px solid rgba(17,23,23,.08);font-size:.77rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft)}
.eyebrow::before{content:"";width:9px;height:9px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--gold))}
.section-copy{max-width:700px}
.section-copy h2,.cta-copy h2,.hero-copy h1{font-family:"Space Grotesk",sans-serif}
.section-copy h2{font-size:clamp(2rem,5vw,3.35rem);line-height:1.02;letter-spacing:-.06em;margin:16px 0 12px}
.section-copy p{font-size:1.04rem;color:var(--ink-soft);max-width:60ch}
.hero{padding:34px 0 26px}
.hero-shell{position:relative;overflow:hidden;border:1px solid rgba(17,23,23,.08);border-radius:40px;background:linear-gradient(180deg,rgba(255,250,241,.92),rgba(255,255,255,.8));box-shadow:var(--shadow)}
.hero-shell::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 10% 12%,rgba(246,107,45,.16),transparent 26%),radial-gradient(circle at 88% 16%,rgba(135,199,223,.26),transparent 28%),linear-gradient(180deg,rgba(255,255,255,.34),transparent 60%);pointer-events:none}
.hero-grid{position:relative;display:grid;gap:24px;padding:24px}
.hero-copy h1{font-size:clamp(2.7rem,8vw,5.5rem);line-height:.92;letter-spacing:-.08em;max-width:10.5ch;margin:18px 0 18px}
.hero-copy p{font-size:1.08rem;color:#394447;max-width:58ch}
.hero-actions{display:flex;flex-direction:column;gap:12px;margin-top:26px}
.hero-note{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}
.pill{display:inline-flex;align-items:center;gap:8px;padding:10px 12px;border-radius:999px;background:rgba(255,255,255,.72);border:1px solid rgba(17,23,23,.08);font-size:.88rem;color:var(--ink-soft)}
.pill strong{color:var(--ink)}
.launch-chip{display:inline-flex;align-items:center;gap:8px;padding:11px 14px;border-radius:16px;background:var(--cream);border:1px solid rgba(246,107,45,.18);color:#7a3b1b;font-size:.92rem;font-weight:700}
.launch-chip .dot{width:10px;height:10px;border-radius:50%;background:var(--brand)}
.hero-layout{display:grid;gap:16px}
.hero-panel,.product-card,.metric-card,.reason-card,.faq-item,.cta-shell,.proof-band,.story-card,.phone-card,.chat-card,.hero-side-note{border:1px solid rgba(17,23,23,.08);border-radius:var(--radius-lg);background:rgba(255,255,255,.7);box-shadow:var(--shadow-soft)}
.hero-panel{padding:18px;background:rgba(18,33,42,.96);color:#eef8f5}
.hero-panel h3,.phone-top strong,.product-card h3,.reason-card h3,.story-card h3,.faq-item summary,.metric-card h3{font-size:1.05rem;letter-spacing:-.03em}
.hero-panel p,.hero-panel li{color:rgba(238,248,245,.82)}
.hero-panel ul{padding-left:18px;margin-top:12px}
.hero-panel li+li{margin-top:8px}
.hero-proof{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:16px}
.proof-mini{padding:16px;border-radius:18px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.08)}
.proof-mini strong{display:block;font-family:"Space Grotesk",sans-serif;font-size:1.4rem;letter-spacing:-.05em}
.proof-mini span{font-size:.9rem;color:rgba(238,248,245,.76)}
.hero-visual{display:grid;gap:14px}
.chat-card{padding:14px;background:linear-gradient(180deg,#0d3d2f,#11533f);color:#effcf4;overflow:hidden}
.chat-top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
.chat-top strong{font-size:1.02rem;letter-spacing:-.02em}
.chat-tag{padding:7px 10px;border-radius:999px;background:rgba(255,255,255,.12);font-size:.76rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
.chat-shell{padding:12px;border-radius:24px;background:linear-gradient(180deg,#efe3d0,#e5d6c2);display:grid;gap:12px;color:#17222a}
.chat-meta{display:flex;justify-content:space-between;gap:12px;font-size:.84rem;color:#5e6a6e}
.chat-thread{display:grid;gap:10px}
.bubble{max-width:85%;padding:12px 14px;border-radius:18px;box-shadow:0 10px 22px rgba(30,26,12,.08)}
.bubble strong{display:block;font-size:.94rem;margin-bottom:4px}
.bubble small{display:block;margin-top:6px;font-size:.73rem;opacity:.72}
.bubble.in{justify-self:start;background:#fff6ea;border-top-left-radius:8px}
.bubble.out{justify-self:end;background:#d7f9cf;border-top-right-radius:8px}
.chat-progress{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 14px;border-radius:18px;background:#fffaf2;border:1px solid rgba(17,23,23,.08)}
.progress-copy strong{display:block;font-size:.96rem}
.progress-copy span{font-size:.84rem;color:#5e6a6e}
.progress-chip{padding:8px 10px;border-radius:999px;background:#143022;color:#effcf4;font-size:.8rem;font-weight:800}
.hero-side-note{padding:18px;background:linear-gradient(180deg,rgba(255,255,255,.84),rgba(249,241,228,.98))}
.hero-side-note h3{font-size:1rem;margin-bottom:10px;letter-spacing:-.02em}
.hero-side-note ul{padding-left:18px;color:var(--ink-soft)}
.hero-side-note li+li{margin-top:8px}
.phone-card{padding:14px;background:linear-gradient(180deg,#17242c,#223640);color:#eaf3ef;overflow:hidden}
.phone-top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:14px}
.phone-tag{padding:7px 10px;border-radius:999px;background:rgba(255,255,255,.1);font-size:.76rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
.screen{padding:14px;border-radius:22px;background:linear-gradient(180deg,#fef8f0,#f4eadb);color:var(--ink);display:grid;gap:12px}
.screen-bar{display:flex;justify-content:space-between;gap:10px;font-size:.9rem;color:var(--ink-soft)}
.screen-title{font-family:"Space Grotesk",sans-serif;font-size:1.36rem;letter-spacing:-.05em}
.sale-flow{display:grid;gap:10px}
.sale-step{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 14px;border-radius:18px;background:#fffdf9;border:1px solid rgba(17,23,23,.08)}
.sale-step strong{font-size:.96rem}
.sale-step span{font-size:.86rem;color:var(--ink-soft)}
.reward-banner{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 14px;border-radius:18px;background:#143022;color:#eaf8f0}
.reward-banner strong{font-family:"Space Grotesk",sans-serif;font-size:1.15rem}
.mock-phone-image{border-radius:24px;overflow:hidden;border:1px solid rgba(255,255,255,.1)}
.mock-phone-image img{width:100%;height:246px;object-fit:cover;filter:saturate(1.05)}
.proof-section{padding-top:24px}
.proof-band{padding:22px;background:linear-gradient(135deg,rgba(255,255,255,.76),rgba(255,248,235,.92))}
.proof-grid,.metrics-grid,.reasons-grid,.story-grid,.faq-grid{display:grid;gap:14px}
.proof-grid{margin-top:18px}
.metric-card{padding:20px;background:var(--panel-strong)}
.metric-card h3{margin-bottom:8px}
.metric-card p{color:var(--ink-soft)}
.product-grid{display:grid;gap:16px;margin-top:22px}
.product-card{padding:22px;background:rgba(255,255,255,.74)}
.product-card h3{margin-bottom:10px}
.product-card p{color:var(--ink-soft)}
.step-line{display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border-radius:16px;background:linear-gradient(135deg,var(--brand),#ffa56a);color:#fff;font-family:"Space Grotesk",sans-serif;font-size:1.1rem;margin-bottom:14px}
.story-grid{margin-top:22px}
.story-card{padding:22px;background:linear-gradient(180deg,rgba(255,255,255,.76),rgba(249,241,228,.96))}
.story-card p{color:var(--ink-soft)}
.story-card p + p{margin-top:12px}
.story-card ul{padding-left:18px;margin-top:12px;color:var(--ink-soft)}
.story-card li+li{margin-top:8px}
.story-link{margin-top:18px}
.reasons-grid{margin-top:22px}
.reason-card{padding:22px;background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(255,253,248,.96))}
.reason-card p{color:var(--ink-soft)}
.reason-icon{display:inline-flex;align-items:center;justify-content:center;width:46px;height:46px;border-radius:16px;background:rgba(246,107,45,.12);border:1px solid rgba(246,107,45,.18);color:var(--brand-deep);margin-bottom:14px}
.reason-icon svg{width:22px;height:22px;display:block}
.faq-grid{margin-top:22px}
.faq-item{overflow:hidden;background:rgba(255,255,255,.82)}
.faq-item summary{list-style:none;cursor:pointer;padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:"+";font-size:1.4rem;color:var(--brand-deep);transition:transform .2s ease}
.faq-item[open] summary::after{transform:rotate(45deg)}
.faq-item p{padding:0 22px 20px;color:var(--ink-soft)}
.cta-shell{padding:28px;background:linear-gradient(140deg,#102029 0%,#18323d 60%,#21495b 100%);color:#f4fbfb;overflow:hidden;position:relative}
.cta-shell::before{content:"";position:absolute;inset:auto -100px -120px auto;width:260px;height:260px;border-radius:50%;background:rgba(235,184,79,.18);filter:blur(8px)}
.cta-layout{position:relative;display:grid;gap:18px}
.cta-copy h2{font-size:clamp(2rem,5vw,3.3rem);line-height:1.01;letter-spacing:-.06em;margin:16px 0 12px}
.cta-copy p{font-size:1.03rem;color:rgba(244,251,251,.8);max-width:58ch}
.cta-actions{display:flex;flex-direction:column;gap:12px;margin-top:22px}
.cta-side{padding:18px;border-radius:20px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1)}
.cta-side h3{font-size:1rem;margin-bottom:10px}
.cta-side p,.cta-side li{color:rgba(244,251,251,.78)}
.cta-side ul{padding-left:18px}
.cta-side li+li{margin-top:8px}
.site-footer{padding:24px 0 94px}
.footer-shell{display:grid;gap:10px;padding:18px 0;color:var(--ink-soft);font-size:.94rem}
.footer-links{display:flex;flex-wrap:wrap;gap:14px}
.mobile-cta{position:fixed;left:12px;right:12px;bottom:12px;z-index:40;display:flex;justify-content:center;padding-bottom:calc(env(safe-area-inset-bottom,0px))}
.mobile-cta .btn{width:min(100%,560px)}
.mobile-cta{opacity:0;transform:translateY(18px);pointer-events:none;transition:opacity .22s ease,transform .22s ease}
.mobile-cta.is-visible{opacity:1;transform:none;pointer-events:auto}
.reveal{opacity:0;transform:translateY(20px);transition:opacity .55s ease,transform .55s ease}
.reveal.in{opacity:1;transform:none}
@media (max-width:759px){
  .site-header .wrap{gap:10px;padding:10px 0;align-items:flex-start}
  .brand{flex:1 1 auto;min-width:0}
  .brand img{width:38px;height:38px}
  .brand-copy strong{font-size:.94rem}
  .brand-copy span{font-size:.72rem}
  .header-actions{flex:0 0 auto}
  .header-actions .btn-ghost{display:none}
  .header-actions .btn-primary{min-height:44px;padding:0 14px;font-size:.88rem;white-space:nowrap}
  .section{padding:56px 0}
  .hero{padding:20px 0 16px}
  .hero-shell{border-radius:28px}
  .hero-grid{gap:18px;padding:18px}
  .hero-copy h1{font-size:clamp(2.4rem,14vw,4.2rem);max-width:8.6ch;margin:14px 0 14px}
  .hero-copy p{font-size:1rem;max-width:34ch}
  .hero-actions{margin-top:18px}
  .hero-note{margin-top:14px}
  .launch-chip{width:100%;justify-content:flex-start}
  .pill{font-size:.84rem;padding:9px 11px}
  .hero-panel,.phone-card,.chat-card,.hero-side-note,.product-card,.metric-card,.reason-card,.story-card,.cta-shell{padding:16px}
  .hero-proof{grid-template-columns:1fr}
  .proof-mini{padding:14px}
  .bubble{max-width:92%}
  .chat-progress{align-items:flex-start;flex-direction:column}
  .screen-title{font-size:1.2rem}
  .sale-step{padding:11px 12px}
  .reward-banner{align-items:flex-start;flex-direction:column}
  .mock-phone-image img{height:200px}
  .section-copy h2{font-size:clamp(1.8rem,10vw,2.4rem)}
  .proof-band{padding:18px}
  .product-grid,.story-grid,.reasons-grid,.faq-grid,.proof-grid{gap:12px}
  .step-line{width:38px;height:38px}
  .faq-item summary{padding:18px}
  .faq-item p{padding:0 18px 18px}
  .cta-copy h2{font-size:clamp(1.85rem,10vw,2.5rem)}
  .cta-actions .btn{width:100%}
  .footer-shell{padding-bottom:10px}
}
@media (min-width:760px){
  .wrap{width:min(var(--max),calc(100% - 56px))}
  .nav{display:flex}
  .hero-grid{grid-template-columns:minmax(0,1.05fr) minmax(0,.95fr);padding:36px}
  .hero-actions,.cta-actions{flex-direction:row;flex-wrap:wrap}
  .proof-grid,.metrics-grid,.reasons-grid,.faq-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  .product-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
  .story-grid{grid-template-columns:1.15fr .85fr}
  .cta-layout{grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr);align-items:start}
  .mobile-cta{display:none}
  .site-footer{padding-bottom:32px}
}
@media (min-width:1040px){
  .proof-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
  .reasons-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
}
@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  .btn,.reveal,.faq-item summary::after,.nav a{transition:none}
}
</style>
</head>
<body>
<a class="skip-link" href="#main">Ir para o conteúdo</a>

<header class="site-header">
  <div class="wrap">
    <a class="brand" href="#top" aria-label="MaisUm">
      <img src="../assets/images/logo.png" alt="MaisUm logo" width="42" height="42">
      <div class="brand-copy">
        <strong>MaisUm</strong>
        <span>Maputo. Clientes voltam.</span>
      </div>
    </a>
    <nav class="nav" aria-label="Navegação principal">
      <a href="#before-after">Antes e depois</a>
