</div>

<script>
window.plausible=window.plausible||function(){(window.plausible.q=window.plausible.q||[]).push(arguments);};

(function(){
  const configuredDomain=document.querySelector('meta[name="plausible-domain"]')?.content.trim();
  const host=window.location.hostname;
  const skipPlausible=window.location.protocol==='file:'||!host||host==='localhost'||host==='127.0.0.1';

  if(!skipPlausible){
    const script=document.createElement('script');
    script.defer=true;
    script.dataset.domain=configuredDomain||host;
    script.src='https://plausible.io/js/script.js';
    document.head.appendChild(script);
  }

  document.querySelectorAll('[data-plausible-event]').forEach((link)=>{
    link.addEventListener('click',()=>{
      const eventName=link.getAttribute('data-plausible-event');
      window.plausible(eventName,{props:{cta_text:link.textContent.trim(),cta_href:link.getAttribute('href')||''}});
    });
  });

  const mobileCta=document.querySelector('.mobile-cta');
  const heroSection=document.querySelector('.hero');
  const syncMobileCta=()=>{
    if(!mobileCta||!heroSection) return;
    if(window.innerWidth>=760){
      mobileCta.classList.remove('is-visible');
      return;
    }
    const heroBottom=heroSection.getBoundingClientRect().bottom;
    const shouldShow=heroBottom<window.innerHeight*.55;
    mobileCta.classList.toggle('is-visible',shouldShow);
  };

  syncMobileCta();
  window.addEventListener('scroll',syncMobileCta,{passive:true});
  window.addEventListener('resize',syncMobileCta);

  if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){
    document.querySelectorAll('.reveal').forEach((el)=>el.classList.add('in'));
    return;
  }

  const observer=new IntersectionObserver((entries)=>{
    entries.forEach((entry)=>{
      if(entry.isIntersecting){
        entry.target.classList.add('in');
        observer.unobserve(entry.target);
      }
    });
  },{threshold:.14});

  document.querySelectorAll('.reveal').forEach((element)=>observer.observe(element));
})();
</script>
</body>
